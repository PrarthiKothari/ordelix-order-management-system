260330  7:27:29	     8 Query	CREATE FUNCTION fn_calculate_order_total(
fn_order_id INT
)
RETURNS DECIMAL(12,2)
DETERMINISTIC
BEGIN
DECALRE validate_total DECIMAL(12,2);

SELECT SUM(oi.quantity * oi.price * (1+ (p.gst_percent / 100))) INTO validate_total
FROM order_items oi
JOIN products p ON oi.product_id = p.product_id
WHERE oi.order_id = fn_order_id;

RETURN IFNULL(validate_total,0);
END
