260330  9:15:22	     8 Query	DROP TRIGGER trg_order_cancel
260330  9:24:21	     8 Query	CREATE TRIGGER trg_order_cancel
AFTER UPDATE ON orders
FOR EACH ROW
BEGIN
DECLARE validate_shipment_id INT;

IF OLD.status <> 'CANCELLED' AND NEW.status = 'CANCELLED' THEN

UPDATE inventory i
JOIN order_items oi ON i.product_id = oi.product_id
SET i.stock_quantity = i.stock_quantity + oi.quantity
WHERE oi.order_id = NEW.order_id;

UPDATE products p
JOIN inventory i ON p.product_id = i.product_id
SET p.status = 'ACTIVE'
WHERE i.stock_quantity > 0;

SELECT shipment_id INTO validate_shipment_id FROM shipments
WHERE order_id = NEW.order_id
LIMIT 1;

UPDATE shipments SET status = 'CANCELLED'
WHERE order_id = NEW.order_id;

INSERT INTO audit_logs(table_name, action_type, record_id, description)
VALUES ('orders', 'UPDATE', NEW.order_id, 'Order cancelled. Inventory restored');
IF validate_shipment_id IS NOT NULL THEN
INSERT INTO audit_logs(table_name, action_type, record_id, description)
VALUES ('shipments', 'UPDATE', validate_shipment_id, CONCAT('Shipment cancelled for order_id: ', NEW.order_id));
END IF;

END IF;

END
260330  9:48:22	     8 Query	DROP PROCEDURE sp_place_order
260330  9:59:18	     8 Query	CREATE PROCEDURE sp_place_order(
IN sp_customer_id INT,
IN sp_address_id INT
)
BEGIN
DECLARE validate_cart_id INT;
DECLARE validate_order_id INT;
DECLARE validate_total DECIMAL(12,2);

START TRANSACTION;

SELECT cart_id INTO validate_cart_id FROM cart WHERE customer_id = sp_customer_id;

IF EXISTS(
SELECT 1 FROM cart_items ci
JOIN inventory i ON ci.product_id = i.product_id
WHERE ci.cart_id = validate_cart_id
AND i.stock_quantity < ci.quantity
)
THEN
SIGNAL SQLSTATE '45000'
SET MESSAGE_TEXT = 'Insufficient stock for one or more products';
END IF;

INSERT INTO orders(order_uuid, customer_id, address_id, status, total_amount)
VALUES(UUID(), sp_customer_id, sp_address_id, 'PLACED', 0);

SET validate_order_id = LAST_INSERT_ID();

INSERT INTO order_items(order_id, product_id, quantity, price)
SELECT validate_order_id, ci.product_id, ci.quantity, p.price
FROM cart_items ci
JOIN products p ON ci.product_id = p.product_id
WHERE ci.cart_id = validate_cart_id;

UPDATE inventory i
JOIN cart_items ci ON i.product_id = ci.product_id
SET i.stock_quantity = i.stock_quantity - ci.quantity
WHERE ci.cart_id = validate_cart_id;

SELECT fn_calculate_order_total(validate_order_id) INTO validate_total;

UPDATE orders SET total_amount = validate_total
WHERE order_id = validate_order_id;

DELETE FROM cart_items WHERE cart_id = validate_cart_id;

COMMIT;

END
260330 10:09:12	     8 Query	CREATE TRIGGER trg_inventory_alerts
AFTER UPDATE ON inventory
FOR EACH ROW
BEGIN

IF NEW.stock_quantity < 10 AND OLD.stock_quantity >= 10 THEN
INSERT INTO audit_logs(table_name, action_type, record_id, description)
VALUES ('inventory', 'UPDATE', NEW.inventory_id, CONCAT('LOW STOCK ALERT - product_id: ', NEW.product_id, ', stock_quantity: ', NEW.stock_quantity));
END IF;

IF NEW.stock_quantity < 3 AND OLD.stock_quantity >= 3 THEN
INSERT INTO audit_logs(table_name, action_type, record_id, description)
VALUES ('inventory', 'UPDATE', NEW.inventory_id, CONCAT('CRITICAL STOCK ALERT - product_id: ', NEW.product_id, ', stock_quantity: ', NEW.stock_quantity));
END IF;

IF NEW.stock_quantity = 0 AND OLD.stock_quantity > 0 THEN

UPDATE products SET status = 'INACTIVE'
WHERE product_id = NEW.product_id;

INSERT INTO audit_logs(table_name, action_type, record_id, description)
VALUES ('inventory', 'UPDATE', NEW.inventory_id, CONCAT('OUT OF STOCK - product_id: ', NEW.product_id));

INSERT INTO audit_logs(table_name, action_type, record_id, description)
VALUES ('products', 'UPDATE', NEW.product_id, 'Product auto-disabled due to zero stock');
END IF;

END
