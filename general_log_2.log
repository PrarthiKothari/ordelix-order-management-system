260330 10:34:39	     8 Query	CREATE FUNCTION fn_order_status(
fn_order_id INT
)
RETURNS VARCHAR(50)
READS SQL DATA
BEGIN
DECLARE validate_status VARCHAR(20);

SELECT status INTO validate_status FROM orders
WHERE order_id = fn_order_id;

RETURN CASE
WHEN validate_status = 'PLACED' THEN 'Order Placed'
WHEN validate_status = 'PAID' THEN 'Payment Completed'
WHEN validate_status = 'SHIPPED' THEN 'In Transit'
WHEN validate_status = 'DELIVERED' THEN 'Order Delivered'
WHEN validate_status = 'CANCELLED' THEN 'Order Cancelled'
ELSE 'Unknown'
END;

END
